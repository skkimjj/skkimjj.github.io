---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('naver');
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} noindex={true}>
  <div class="copy-hint">
    네이버 발행용 원본 페이지입니다. 아래 본문을 전체 선택(⌘A 영역 드래그)해서
    네이버 블로그 편집기에 붙여넣으세요. 제목은 별도로 복사해 제목란에
    넣습니다.
  </div>
  <p class="naver-title-line"><strong>제목:</strong> {entry.data.title}</p>
  <article class="naver-body">
    <Content />
  </article>
</Base>

<script>
  // 네이버 편집기는 CSS class가 아니라 인라인 style만 복붙에 반영한다.
  // 붉은 강조(strong)와 형광펜(mark)에 인라인 style을 주입해 복붙 시 색이 따라가게 한다.
  const body = document.querySelector('.naver-body');
  if (body) {
    body.querySelectorAll('strong').forEach((el) => {
      (el as HTMLElement).style.color = '#c0392b';
    });
    body.querySelectorAll('mark').forEach((el) => {
      (el as HTMLElement).style.backgroundColor = '#fff3a6';
      (el as HTMLElement).style.color = 'inherit';
    });
  }
</script>

<style>
  .copy-hint {
    background: #fff7e6;
    border: 1px solid #f0d9a8;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    color: #7a5b00;
    margin-bottom: 1.5rem;
  }
  .naver-title-line {
    color: var(--muted);
    font-size: 0.9rem;
    border-bottom: 1px dashed var(--line);
    padding-bottom: 1rem;
  }
  /* 네이버 편집기는 그라데이션을 못 가져가므로 단색 배경으로 (복붙 호환) */
  .naver-body :global(mark) {
    background: #fff3a6;
    background-image: none;
  }
</style>
