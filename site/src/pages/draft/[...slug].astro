---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('drafts');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const home = import.meta.env.BASE_URL;
const fmt = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`[초안] ${post.data.title}`} noindex={true}>
  <div class="draft-banner">
    ✍️ <strong>발행 전 초안입니다.</strong> 이 페이지는 검색·목록에 노출되지 않습니다(noindex).
    검수 후 발행하려면 대화에서 “<code>{post.id}</code> 발행”이라고 알려주세요.
  </div>
  <article>
    <p class="eyebrow">
      📚 투자 공부방{post.data.series && ` · ${post.data.series}`}
      {post.data.seriesOrder && ` ${post.data.seriesOrder}`}
    </p>
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
      {
        post.data.tags.length > 0 && (
          <span class="tags">
            {post.data.tags.map((t) => (
              <span class="tag">#{t}</span>
            ))}
          </span>
        )
      }
    </div>
    <Content />
    <p class="back-link"><a href={`${home}draft/`}>← 초안 목록</a></p>
  </article>
</Base>

<style>
  .draft-banner {
    background: #fff7e6;
    border: 1px solid #f0d9a8;
    border-radius: 8px;
    padding: 0.85rem 1rem;
    font-size: 0.88rem;
    color: #7a5b00;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .draft-banner code {
    background: #fff;
    border: 1px solid #e5d3a0;
    border-radius: 4px;
    padding: 0.05rem 0.35rem;
    font-size: 0.85em;
  }
  .eyebrow {
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    margin: 0 0 0.4rem;
  }
  .post-meta {
    margin-bottom: 2rem;
    color: var(--muted);
    font-size: 0.85rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
    font-size: 0.75rem;
  }
  .back-link {
    margin-top: 2rem;
    font-size: 0.9rem;
  }
  .back-link a {
    text-decoration: none;
  }
</style>
