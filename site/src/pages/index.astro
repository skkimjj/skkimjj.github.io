---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const briefings = (await getCollection('briefings')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmt = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'short',
});
---

<Base
  title="개장 전 브리핑"
  description="매일 아침 한국 증시 개장 전, 밤사이 미국 시장과 주요 지표를 팩트 중심으로 정리한 브리핑"
>
  {briefings.length === 0 && <p>아직 발행된 브리핑이 없습니다.</p>}
  <ul class="post-list">
    {
      briefings.map((post) => (
        <li>
          <a href={`${import.meta.env.BASE_URL}briefing/${post.id}/`}>
            {post.data.title}
          </a>
          <time datetime={post.data.date.toISOString()}>
            {fmt.format(post.data.date)}
          </time>
          {post.data.description && <p>{post.data.description}</p>}
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list li {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--line);
  }
  .post-list a {
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
  }
  .post-list a:hover {
    text-decoration: underline;
  }
  .post-list time {
    display: block;
    color: var(--muted);
    font-size: 0.82rem;
    margin-top: 0.2rem;
  }
  .post-list p {
    margin: 0.4rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
