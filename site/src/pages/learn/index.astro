---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('learn')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const home = import.meta.env.BASE_URL;
const fmt = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title="투자 공부방 — 개장 전 브리핑"
  description="주식·ETF·투자 제도를 초보 눈높이에서 실제 데이터로 쉽게 풀어주는 교육 콘텐츠 모음. 매주 주말·공휴일 업데이트."
>
  <header class="learn-intro">
    <p class="eyebrow">📚 투자 공부방</p>
    <h1>초보를 위한, 팩트로 배우는 투자</h1>
    <p class="lede">
      어려운 용어와 숫자를 초보 눈높이에서 하나씩 풀어드립니다. 모든 데이터는
      기준 시점과 출처를 함께 밝힙니다. 개장일에는 <a href={home}>데일리 브리핑</a>,
      장이 쉬는 주말·공휴일에는 이곳 공부방 글이 올라옵니다.
    </p>
  </header>

  {posts.length === 0 && <p>아직 발행된 글이 없습니다.</p>}
  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <a href={`${home}learn/${post.id}/`}>{post.data.title}</a>
          <time datetime={post.data.date.toISOString()}>
            {fmt.format(post.data.date)}
          </time>
          {post.data.description && <p class="desc">{post.data.description}</p>}
          {post.data.tags.length > 0 && (
            <span class="tags">
              {post.data.tags.map((t) => (
                <span class="tag">#{t}</span>
              ))}
            </span>
          )}
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .learn-intro {
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .eyebrow {
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    margin: 0 0 0.3rem;
  }
  .learn-intro h1 {
    margin: 0 0 0.6rem;
  }
  .lede {
    color: var(--muted);
    font-size: 0.95rem;
    margin: 0;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list li {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--line);
  }
  .post-list > li > a {
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
  }
  .post-list > li > a:hover {
    text-decoration: underline;
  }
  .post-list time {
    display: block;
    color: var(--muted);
    font-size: 0.82rem;
    margin-top: 0.2rem;
  }
  .post-list .desc {
    margin: 0.4rem 0 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
    font-size: 0.75rem;
    color: var(--muted);
  }
</style>
